@model DigitalGoldWallet.MVC.Models.RegisterViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Register";
}

<style>
    body {
        background: #f8f1e5;
    }

    .register-panel {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 100vh;
    }

    .register-copy {
        background: linear-gradient(135deg, #2b2112, #7a5a16);
        color: white;
        padding: 4rem;
    }

    .register-chip {
        display: inline-block;
        padding: 0.45rem 1rem;
        border-radius: 50px;
        background: rgba(255, 215, 90, 0.2);
        color: #ffd966;
        font-weight: 700;
        margin-bottom: 1rem;
        text-transform: uppercase;
        font-size: 0.85rem;
    }

    .register-copy h1 {
        font-size: 3.5rem;
        font-weight: 800;
        line-height: 1.05;
        margin-bottom: 1rem;
    }

    .register-copy p {
        color: rgba(255, 255, 255, 0.82);
        font-size: 1.05rem;
        max-width: 420px;
    }

    .register-form-wrap {
        background: #fbf4ea;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem;
    }

    .register-form-card {
        width: min(100%, 430px);
        background: white;
        padding: 2rem;
        border-radius: 24px;
        box-shadow: 0 18px 45px rgba(90, 65, 20, 0.16);
        border: 1px solid #eadcc5;
    }

        .register-form-card h2 {
            font-size: 2.4rem;
            font-weight: 800;
            color: #3b2d08;
            margin-bottom: 0.5rem;
        }

        .register-form-card p {
            color: #8a7a61;
            margin-bottom: 1.5rem;
        }

        .register-form-card label {
            font-weight: 700;
            color: #5c4a2d;
            margin-bottom: 0.45rem;
        }

        .register-form-card .form-control {
            min-height: 52px;
            border-radius: 14px;
            border: 1px solid #dfcfb6;
            box-shadow: none;
        }

            .register-form-card .form-control:focus {
                border-color: #d8b22f;
                box-shadow: 0 0 0 0.2rem rgba(216, 178, 47, 0.18);
            }

    .register-btn {
        min-height: 52px;
        border: 0;
        border-radius: 14px;
        background: #d8b22f;
        color: #3b2d08;
        font-weight: 800;
    }

        .register-btn:hover {
            background: #c79f22;
            color: #2d2106;
        }

    .register-link {
        color: #9b7313;
        font-weight: 700;
        text-decoration: none;
    }

        .register-link:hover {
            text-decoration: underline;
        }

    .text-danger {
        font-size: 0.85rem;
    }

    @@media (max-width: 992px) {
        .register-panel {
            grid-template-columns: 1fr;
        }

        .register-copy {
            padding: 2rem;
        }

            .register-copy h1 {
                font-size: 2.5rem;
            }
    }
</style>

<section class="register-panel">

    <!-- LEFT SIDE -->

    <div class="register-copy d-flex align-items-center justify-content-center">

        <div class="text-center px-4">

            <span class="register-chip">
                Digital Gold Wallet
            </span>

            <h1>
                Create Your Account
            </h1>

            <p>
                Register to securely buy, sell, and manage digital gold assets.
            </p>

        </div>

    </div>

    <!-- RIGHT SIDE -->

    <div class="register-form-wrap">

        <div class="register-form-card">

            <h2>Register</h2>

            <p>
                Create your account to continue.
            </p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form method="post"
                  asp-controller="Auth"
                  asp-action="Register">

                <!-- NAME -->

                <div class="mb-3">

                    <label asp-for="Name">
                        Full Name
                    </label>

                    <input asp-for="Name"
                           class="form-control"
                           placeholder="Enter your name" />

                    <span asp-validation-for="Name"
                          class="text-danger"></span>

                </div>

                <!-- EMAIL -->

                <div class="mb-3">

                    <label asp-for="Email">
                        Email
                    </label>

                    <input asp-for="Email"
                           class="form-control"
                           placeholder="Enter your email" />

                    <span asp-validation-for="Email"
                          class="text-danger"></span>

                </div>

                <!-- PASSWORD -->

                <div class="mb-3">

                    <label asp-for="Password">
                        Password
                    </label>

                    <input asp-for="Password"
                           type="password"
                           class="form-control"
                           placeholder="Enter your password" />

                    <span asp-validation-for="Password"
                          class="text-danger"></span>

                </div>

                <!-- ADDRESS ID -->

                <div class="mb-4">

                    <label asp-for="AddressId">
                        Address Id
                    </label>

                    <input asp-for="AddressId"
                           class="form-control"
                           placeholder="Enter address id" />

                    <span asp-validation-for="AddressId"
                          class="text-danger"></span>

                </div>

                <!-- BUTTON -->

                <button class="btn register-btn w-100"
                        type="submit">
                    Register
                </button>

                <!-- LOGIN -->

                <div class="text-center mt-4">

                    <span style="color:#8a7a61;">
                        Already have an account?
                    </span>

                    <a asp-controller="Auth"
                           asp-action="Login"
                           class="register-link">
                        Login here
                    </a>

                </div>

            </form>

        </div>

    </div>

</section>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}