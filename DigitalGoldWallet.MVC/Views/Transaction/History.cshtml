@{
    ViewData["Title"] = "Transaction History";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    string role = Context.Session.GetString("UserRole")
        ?? Context.Session.GetString("Role")
        ?? string.Empty;

    Layout = role.Equals("Vendor", StringComparison.OrdinalIgnoreCase)
        ? "_VendorLayout"
        : "_Layout";

    ViewData["Title"] = "Transactions";
    ViewData["PageHeader"] = "Transactions";
}

<div class="max-w-7xl mx-auto">
    <section class="mb-10">
        <h1 class="text-4xl font-bold text-[#1f1b13] mb-2">
            Transaction History
        </h1>
        <p class="text-[#5f5e5e] text-lg">
            A complete record of your gold purchases, sales, and transfers.
        </p>
    </section>

    <div class="bg-white rounded-2xl border border-[#e9ecef] shadow-sm overflow-hidden">
        <div class="p-8 text-center py-20">
            <div class="w-20 h-20 bg-[#fbf3e5] rounded-full flex items-center justify-center mx-auto mb-6">
                <span class="material-symbols-outlined text-[#d4af37] text-4xl">receipt_long</span>
            </div>
            <h3 class="text-2xl font-bold text-[#1f1b13] mb-3">No transactions to display</h3>
            <p class="text-[#6c757d] max-w-md mx-auto">
                Once you start buying or selling gold, your transaction history will appear here.
            </p>
            <div class="mt-10">
                <a asp-controller="Gold" asp-action="Index" class="bg-[#d4af37] text-[#554300] px-8 py-3 rounded-xl font-bold shadow-sm hover:scale-105 transition">
                    Explore Gold Options
                </a>
            </div>
        </div>
    </div>

<div class="rounded-2xl border border-line bg-white p-10 shadow-soft">
    <h2 class="text-3xl font-extrabold">Transactions</h2>
    <p class="mt-3 text-muted">Transaction module route is working. Your teammate can connect this page to the transaction API module.</p>
</div>
