@model DigitalGoldWallet.MVC.ViewModels.Transaction.GoldPaymentViewModel

@{
    Layout = "~/Views/Shared/_PaymentLayout.cshtml";

    ViewData["Title"] = "Wallet Gold Payment";
}

<div class="max-w-5xl mx-auto space-y-8">

    <div>
        <h2 class="text-4xl font-extrabold tracking-tight">Wallet Payment</h2>
        <p class="mt-2 text-muted text-lg">
            Review your gold transaction and pay using wallet balance.
        </p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="rounded-2xl border border-red-300 bg-red-50 px-5 py-4 text-red-800 font-bold">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="rounded-2xl border border-green-300 bg-green-50 px-5 py-4 text-green-800 font-bold">
            @TempData["Success"]
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- LEFT -->
        <section class="rounded-2xl border border-line bg-white shadow-soft p-7">

            <h3 class="text-2xl font-extrabold mb-6">
                Gold Details
            </h3>

            <div class="space-y-5">

                <div class="flex justify-between">
                    <span class="text-muted font-bold">
                        Branch ID
                    </span>

                    <span class="font-extrabold">
                        #@Model.BranchId
                    </span>
                </div>

                <div class="flex justify-between">
                    <span class="text-muted font-bold">
                        Transaction Type
                    </span>

                    <span class="font-extrabold">
                        @Model.TransactionType
                    </span>
                </div>

                <div class="flex justify-between">
                    <span class="text-muted font-bold">
                        Quantity
                    </span>

                    <span class="font-extrabold">
                        @Model.Quantity gm
                    </span>
                </div>

                <div class="border-t border-line pt-5 flex justify-between text-xl">

                    <span class="font-extrabold">
                        Payable Amount
                    </span>

                    <span class="font-extrabold text-yellow-700">
                        ₹@Model.Amount
                    </span>

                </div>
            </div>
        </section>

        <!-- RIGHT -->
        <section class="rounded-2xl border border-line bg-white shadow-soft p-7">

            <h3 class="text-2xl font-extrabold mb-6">
                Pay From Wallet
            </h3>

            <div class="rounded-2xl bg-[#fff8e1] border border-yellow-200 p-5 mb-6">

                <p class="text-muted font-bold">
                    Available Wallet Balance
                </p>

                <h4 class="text-3xl font-extrabold text-[#554300] mt-2">
                    ₹@Model.WalletBalance
                </h4>

            </div>

            <form asp-controller="Transaction"
                  asp-action="PayGold"
                  method="post">

                <input type="hidden" asp-for="BranchId" />
                <input type="hidden" asp-for="Quantity" />
                <input type="hidden" asp-for="Amount" />
                <input type="hidden" asp-for="TransactionType" />
                <input type="hidden" asp-for="PaymentMethod" />
                <input type="hidden" asp-for="WalletBalance" />

                <div class="rounded-2xl border border-line p-5 mb-6">

                    <div class="flex items-center gap-3">

                        <input type="radio" checked readonly />

                        <div>

                            <p class="font-extrabold text-lg">
                                Wallet
                            </p>

                            <p class="text-muted text-sm">
                                Amount will be deducted from wallet balance.
                            </p>

                        </div>
                    </div>
                </div>

                @if (Model.WalletBalance < Model.Amount)
                {
                    <button type="button"
                            disabled
                            class="w-full rounded-xl bg-gray-300 px-6 py-4 font-extrabold text-gray-600 cursor-not-allowed">

                        Insufficient Wallet Balance

                    </button>
                }
                else
                {
                    <button type="submit"
                            class="w-full rounded-xl bg-yellow-400 px-6 py-4 font-extrabold text-[#554300] hover:bg-yellow-500">

                        Pay ₹@Model.Amount From Wallet

                    </button>
                }

            </form>

        </section>

    </div>

</div>