@model DigitalGoldWallet.MVC.ViewModels.Transaction.TransactionSummaryViewModel

<div class="grid grid-cols-1 md:grid-cols-3 gap-5">
    <div class="rounded-2xl border border-line bg-white shadow-soft p-6">
        <p class="text-muted font-bold">Total Transactions</p>
        <h3 class="text-3xl font-extrabold mt-2">@Model.TotalTransactions</h3>
    </div>

    <div class="rounded-2xl border border-line bg-white shadow-soft p-6">
        <p class="text-muted font-bold">Successful</p>
        <h3 class="text-3xl font-extrabold mt-2 text-green-600">@Model.SuccessfulTransactions</h3>
    </div>

    <div class="rounded-2xl border border-line bg-white shadow-soft p-6">
        <p class="text-muted font-bold">Total Gold Quantity</p>
        <h3 class="text-3xl font-extrabold mt-2">@Model.TotalGoldQuantity gm</h3>
    </div>
</div>