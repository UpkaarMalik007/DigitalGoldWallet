@model List<DigitalGoldWallet.MVC.ViewModels.Transaction.UserTransactionViewModel>

@if (Model == null || !Model.Any())
{
    <div class="p-6 text-center text-muted font-bold">
        No transactions found.
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-[#fff8e1]">
                <tr>
                    <th class="px-6 py-4">Transaction No.</th>
                    <th class="px-6 py-4">Type</th>
                    <th class="px-6 py-4">Quantity</th>
                    <th class="px-6 py-4">Amount</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4">Date</th>
                    <th class="px-6 py-4">Action</th>
                </tr>
            </thead>

            <tbody>
                @{
                    int serialNo = 1;
                }
                @foreach (var item in Model)
                {
                    <tr class="border-t border-line hover:bg-gray-50">
                        <td class="px-6 py-4 font-bold">@serialNo</td>
                        <td class="px-6 py-4">@item.TransactionType</td>
                        <td class="px-6 py-4">@item.Quantity gm</td>
                        <td class="px-6 py-4">₹@item.Amount</td>
                        <td class="px-6 py-4">
                            <span class="rounded-full bg-green-100 text-green-700 px-3 py-1 text-sm font-bold">
                                @item.TransactionStatus
                            </span>
                        </td>
                        <td class="px-6 py-4">@item.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="px-6 py-4">
                            <a asp-controller="Transaction"
                                   asp-action="UserTransactionDetails"
                                   asp-route-id="@item.TransactionId"
                                   class="font-bold text-yellow-700 hover:underline">
                                View full Details
                            </a>
                        </td>
                    </tr>
                    serialNo++;
                }
            </tbody>
        </table>
    </div>
}