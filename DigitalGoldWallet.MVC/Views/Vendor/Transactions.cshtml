@{
    Layout = "~/Views/Shared/_VendorLayout.cshtml";
    ViewData["Title"] = "Vendor Transactions";
    ViewData["PageHeader"] = "Vendor Transactions";
}

<div class="rounded-2xl border border-line bg-white p-10 shadow-soft">
    <h2 class="text-3xl font-extrabold">Vendor Transactions</h2>
    <p class="mt-3 text-muted">Transactions are handled by the transaction module.</p>
    <a asp-controller="Transaction" asp-action="VendorTransactions" class="mt-6 inline-flex rounded-xl bg-gold px-6 py-3 font-extrabold text-[#554300] no-underline">Open Transactions</a>
</div>
