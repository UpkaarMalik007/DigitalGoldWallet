<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Digital Gold Wallet</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Custom Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top bg-white border-bottom py-3">
        <div class="container">
            <a class="navbar-brand text-gold-dark d-flex align-items-center" asp-controller="Gold" asp-action="Dashboard">
                <i class="bi bi-safe2-fill me-2"></i>GOLD<span class="text-dark opacity-50">WALLET</span>
            </a>
            <div class="ms-auto d-flex align-items-center">
                <div class="rounded-circle bg-gold-primary p-2 me-2 text-dark-brown fw-bold d-flex align-items-center justify-content-center" style="width: 35px; height: 35px; font-size: 0.8rem;">
                    TI
                </div>
                <span class="fw-600 small text-dark-brown">Tushar Investor</span>
            </div>
        </div>
    </nav>

    <main role="main">
        @if (ViewContext.RouteData.Values["action"]?.ToString() != "Dashboard")
        {
            <div class="container mt-3 mb-2">
                <a asp-controller="Gold" asp-action="Dashboard" class="btn btn-link text-gold-dark p-0 text-decoration-none fw-bold small">
                    <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                </a>
            </div>
        }
        @RenderBody()
    </main>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
