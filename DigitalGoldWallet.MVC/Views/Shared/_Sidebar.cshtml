@{
    string loggedInName = Context.Session.GetString("UserName") ?? Context.Session.GetString("Name") ?? "User";
    string loggedInRole = Context.Session.GetString("UserRole") ?? Context.Session.GetString("Role") ?? "User";
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    bool isVendor = loggedInRole.Equals("Vendor", StringComparison.OrdinalIgnoreCase);

    string vendorNavClass(params string[] actions) => currentController.Equals("Vendor", StringComparison.OrdinalIgnoreCase)
        && actions.Any(action => currentAction.Equals(action, StringComparison.OrdinalIgnoreCase))
            ? "bg-gold text-[#554300] shadow-sm"
            : "text-[#4d4635] hover:bg-[#eae1d4]";

    string navClass(string controller) => currentController.Equals(controller, StringComparison.OrdinalIgnoreCase)
        ? "bg-gold text-[#554300] shadow-sm"
        : "text-[#4d4635] hover:bg-[#eae1d4]";
}
<aside class="fixed left-0 top-0 h-full w-64 bg-cream-2 border-r border-line flex flex-col px-4 py-6 z-50">
    <a asp-controller="Vendor" asp-action="Dashboard" class="text-[21px] leading-tight font-extrabold text-gold-dark mb-10 px-3 tracking-tight">
        Digital Gold<br />Wallet
    </a>

    <nav class="space-y-2">
        @if (isVendor)
        {
            <a asp-controller="Vendor" asp-action="Dashboard" class="flex items-center gap-3 rounded-xl px-4 py-3 text-[15px] font-semibold transition @vendorNavClass("Dashboard")">
                <span class="material-symbols-outlined text-[26px]">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a asp-controller="Vendor" asp-action="Branches" class="flex items-center gap-3 rounded-xl px-4 py-3 text-[15px] font-semibold transition @vendorNavClass("Branches", "AddBranch")">
                <span class="material-symbols-outlined text-[26px]">store</span>
                <span>Vendor Branches</span>
            </a>
            <a asp-controller="Transaction" asp-action="History" class="flex items-center gap-3 rounded-xl px-4 py-3 text-[15px] font-semibold transition @navClass("Transaction")">
                <span class="material-symbols-outlined text-[26px]">receipt_long</span>
                <span>Transactions</span>
            <a asp-controller="Transaction" asp-action="VendorTransactions" class="flex items-center gap-4 rounded-xl px-4 py-3 text-[16px] transition @vendorNavClass("Transactions")">
                <span class="material-symbols-outlined text-[28px]">receipt_long</span><span>Transactions</span>
            </a>
        }
        else
        {
            <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 rounded-xl px-4 py-3 text-[15px] font-semibold transition @navClass("Home")">
                <span class="material-symbols-outlined text-[26px]">dashboard</span>
                <span>Dashboard</span>
            </a>
            <a asp-controller="Vendor" asp-action="Index" class="flex items-center gap-3 rounded-xl px-4 py-3 text-[15px] font-semibold transition @navClass("Vendor")">
                <span class="material-symbols-outlined text-[26px]">store</span>
                <span>Vendors</span>
            </a>
        }
    </nav>

    <div class="mt-auto border-t border-line pt-6 space-y-4">
        <div class="flex items-center gap-3 px-3">
            <div class="h-11 w-11 rounded-full bg-gold flex items-center justify-center text-[#554300] shrink-0">
                <span class="material-symbols-outlined text-[25px]">person</span>
            </div>
            <div class="min-w-0">
                <p class="font-extrabold text-ink truncate">@loggedInName</p>
                <p class="text-sm text-muted truncate">@loggedInRole</p>
            </div>
        </div>

        <a asp-controller="Account" asp-action="Logout" class="flex items-center gap-3 text-[#4d4635] px-4 py-3 rounded-xl hover:bg-[#eae1d4] font-semibold">
            <span class="material-symbols-outlined text-[26px]">logout</span>
            <span>Logout</span>
        </a>
    </div>
</aside>
