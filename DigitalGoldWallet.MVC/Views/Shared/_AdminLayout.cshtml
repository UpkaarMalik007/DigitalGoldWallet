@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    string loggedInName = Context.Session.GetString("UserName")
        ?? Context.Session.GetString("Name")
        ?? "Admin";

    string initial = string.IsNullOrWhiteSpace(loggedInName)
        ? "A"
        : loggedInName.Trim()[0].ToString().ToUpper();

    string activeClass = "bg-[#d4af37] text-[#554300] shadow-sm";
    string inactiveClass = "text-[#4d4635] hover:bg-[#efe7da]";

    bool isDashboardActive = currentController.Equals("Admin", StringComparison.OrdinalIgnoreCase)
        && currentAction.Equals("Dashboard", StringComparison.OrdinalIgnoreCase);

    bool isUsersActive = currentController.Equals("Admin", StringComparison.OrdinalIgnoreCase)
        && currentAction.Equals("Users", StringComparison.OrdinalIgnoreCase);

    bool isVendorsActive = currentController.Equals("Admin", StringComparison.OrdinalIgnoreCase)
        && currentAction.Equals("Vendors", StringComparison.OrdinalIgnoreCase);

    bool isTransactionsActive = currentController.Equals("Admin", StringComparison.OrdinalIgnoreCase)
        && currentAction.Equals("Transactions", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard - Digital Gold Wallet</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --bg-cream: #fff8f0;
            --sidebar-bg: #fdfaf5;
            --gold-primary: #d4af37;
            --gold-dark: #735c00;
            --gold-light: #efe7da;
            --text-main: #1f1b13;
            --text-muted: #6c757d;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-cream);
            color: var(--text-main);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        .glass-header {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(212, 175, 55, 0.1);
        }

        .sidebar-transition {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .nav-link-active {
            background: var(--gold-primary);
            color: #554300;
            box-shadow: 0 4px 12px rgba(212, 175, 55, 0.2);
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 450, 'GRAD' 0, 'opsz' 24;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #efe7da;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #d4af37;
        }
    </style>
</head>
<body class="bg-[#fff8f0] text-[#1f1b13] overflow-x-hidden">
    <!-- Header -->
    <header class="sticky top-0 z-50 h-20 glass-header flex items-center justify-between px-8 lg:px-12">
        <a asp-controller="Admin" asp-action="Dashboard" class="inline-flex items-center gap-3 text-2xl font-black text-[#735c00] no-underline tracking-tight">
            <span class="material-symbols-outlined text-[26px]">account_balance_wallet</span>
            <span class="hidden sm:inline">Digital Gold Wallet <span class="font-light text-[#a58b3d]">Admin</span></span>
        </a>

        <div class="flex items-center gap-6">
            <div class="hidden md:flex flex-col items-end">
                <span class="text-[11px] font-bold text-[#a58b3d] uppercase tracking-widest">System Controller</span>
                <span class="font-extrabold text-[#1f1b13]">@loggedInName</span>
            </div>
            <div class="w-12 h-12 rounded-full border-2 border-[#d4af37]/20 p-0.5">
                <div class="w-full h-full rounded-full bg-[#d4af37] flex items-center justify-center text-white font-bold text-lg">
                    @initial
                </div>
            </div>
        </div>
    </header>

    <!-- Sidebar -->
    <aside class="fixed left-0 top-20 h-[calc(100vh-5rem)] w-72 bg-[#fdfaf5] border-r border-[#efe7da]/50 hidden md:flex flex-col px-6 py-10 sidebar-transition">
        <div class="space-y-1 mb-10">
            <p class="px-4 text-[10px] font-black text-[#a58b3d] uppercase tracking-[0.2em] mb-4">Core Management</p>
            
            <nav class="flex flex-col gap-1.5">
                <a asp-controller="Admin" asp-action="Dashboard" class="flex items-center gap-3 px-5 py-3.5 rounded-2xl @(isDashboardActive ? activeClass : inactiveClass) font-bold transition-all duration-200 no-underline group">
                    <span class="material-symbols-outlined @(isDashboardActive ? "" : "text-[#a58b3d] group-hover:scale-110") transition-transform">dashboard</span>
                    <span>Dashboard Overview</span>
                </a>

                <a asp-controller="Admin" asp-action="Users" class="flex items-center gap-3 px-5 py-3.5 rounded-2xl @(isUsersActive ? activeClass : inactiveClass) font-bold transition-all duration-200 no-underline group">
                    <span class="material-symbols-outlined @(isUsersActive ? "" : "text-[#a58b3d] group-hover:scale-110") transition-transform">group</span>
                    <span>Users Management</span>
                </a>

                <a asp-controller="Admin" asp-action="Vendors" class="flex items-center gap-3 px-5 py-3.5 rounded-2xl @(isVendorsActive ? activeClass : inactiveClass) font-bold transition-all duration-200 no-underline group">
                    <span class="material-symbols-outlined @(isVendorsActive ? "" : "text-[#a58b3d] group-hover:scale-110") transition-transform">store</span>
                    <span>Vendor Partners</span>
                </a>

                <a asp-controller="Admin" asp-action="Transactions" class="flex items-center gap-3 px-5 py-3.5 rounded-2xl @(isTransactionsActive ? activeClass : inactiveClass) font-bold transition-all duration-200 no-underline group">
                    <span class="material-symbols-outlined @(isTransactionsActive ? "" : "text-[#a58b3d] group-hover:scale-110") transition-transform">history_edu</span>
                    <span>Transactions Ledger</span>
                </a>
            </nav>
        </div>

        <div class="mt-auto pt-6 border-t border-[#efe7da]/50">
            <a asp-controller="Account" asp-action="Logout" class="flex items-center gap-3 px-5 py-3.5 rounded-2xl text-red-600 hover:bg-red-50 font-bold transition-all no-underline group">
                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">logout</span>
                Logout
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="md:ml-72 min-h-[calc(100vh-5rem)] p-10 lg:p-14 overflow-x-hidden">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
