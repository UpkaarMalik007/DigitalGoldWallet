<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Digital Gold Wallet</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
          rel="stylesheet">

    <style>
        body {
        font-family: 'Inter', sans-serif;
        background: #f7f2e9;
        }

        .border-line {
        border-color: #e7dcc7;
        }

        .shadow-soft {
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        .text-muted {
        color: #6b7280;
        }
    </style>
</head>

<body>

    <!-- TOP HEADER -->
    <header class="bg-white border-b border-line shadow-sm">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

            <!-- LOGO -->
            <div>
                <a asp-controller="Home"
                       asp-action="Index"
                       class="text-2xl font-extrabold text-[#554300]">
                    Digital Gold Wallet
                </a>
            </div>

            <!-- USER -->
            <div class="flex items-center gap-5">

                <span class="font-bold text-gray-700">
                    @Context.Session.GetString("UserName")
                </span>

                <a asp-controller="Auth"
                       asp-action="Logout"
                       class="rounded-lg bg-yellow-400 px-4 py-2 font-bold text-[#554300] hover:bg-yellow-500">
                    Logout
                </a>
            </div>
        </div>
    </header>

    <!-- PAGE CONTENT -->
    <main class="max-w-7xl mx-auto px-6 py-10">
        @RenderBody()
    </main>

</body>
</html>