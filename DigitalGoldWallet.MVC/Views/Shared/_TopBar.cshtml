@{
    string pageTitle = ViewData["PageHeader"]?.ToString()
        ?? ViewData["Title"]?.ToString()
        ?? "Digital Gold Wallet";

    string loggedInName = Context.Session.GetString("UserName")
        ?? Context.Session.GetString("Name")
        ?? "User";
}
<header class="sticky top-0 z-40 h-16 bg-cream border-b border-line flex items-center justify-between px-6 xl:px-10">
    <h1 class="text-xl font-extrabold text-gold-dark">@pageTitle</h1>

    <div class="flex items-center gap-5 text-sm font-bold">
        <span class="hidden sm:inline">@loggedInName</span>
        <a asp-controller="Account" asp-action="Logout" class="text-gold-dark hover:underline">Logout</a>
    </div>
</header>
