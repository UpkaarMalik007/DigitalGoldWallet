@model List<DigitalGoldWallet.MVC.ViewModels.User.UserViewModel>
@{
    ViewData["Title"] = "Manage Users";
    Layout = "_AdminLayout";
}

<div class="space-y-12">
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-8">
        <div>
            <h1 class="text-4xl font-black text-[#1f1b13] tracking-tight">Users Directory</h1>
            <p class="text-[#6c757d] text-lg mt-2">Manage and monitor all registered users on the platform.</p>
        </div>
        <div class="flex items-center gap-4">
            <div class="bg-white px-6 py-3 rounded-2xl border border-[#efe7da] shadow-sm flex items-center gap-4">
                <span class="text-sm font-black text-[#a58b3d] uppercase tracking-widest">Total Registered</span>
                <span class="text-3xl font-black text-[#1f1b13]">@ViewBag.TotalCount</span>
            </div>
            <a asp-action="CreateUser" class="px-8 py-4 bg-[#d4af37] text-[#554300] font-black rounded-2xl shadow-lg shadow-[#d4af37]/20 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center gap-2 no-underline">
                <span class="material-symbols-outlined">person_add</span>
                Add User
            </a>
        </div>
    </div>

    <div class="bg-white rounded-[40px] border border-[#efe7da] shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-[#fbf3e5]/50">
                        <th class="px-10 py-5 text-[11px] font-black text-[#735c00] uppercase tracking-[0.2em]">User Profile</th>
                        <th class="px-10 py-5 text-[11px] font-black text-[#735c00] uppercase tracking-[0.2em]">Access Credentials</th>
                        <th class="px-10 py-5 text-[11px] font-black text-[#735c00] uppercase tracking-[0.2em]">Wallet Liquidity</th>
                        <th class="px-10 py-5 text-[11px] font-black text-[#735c00] uppercase tracking-[0.2em] text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#fbf3e5]">
                    @foreach (var user in Model)
                    {
                        <tr class="hover:bg-[#fdf9f0]/30 transition-colors group">
                            <td class="px-10 py-8">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 rounded-2xl bg-[#d4af37] flex items-center justify-center text-white font-black text-lg shadow-lg shadow-[#d4af37]/20">
                                        @user.Name.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="font-black text-[#1f1b13]">@user.Name</div>
                                        <div class="text-[11px] font-bold text-[#a58b3d] uppercase tracking-widest mt-0.5">Active Platform Member</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-10 py-8">
                                <div class="flex items-center gap-2 text-sm font-semibold text-[#4d4635]">
                                    <span class="material-symbols-outlined text-[#6c757d] text-lg">mail</span>
                                    @user.Email
                                </div>
                            </td>
                            <td class="px-10 py-8">
                                <div class="inline-flex items-center px-4 py-1.5 rounded-full text-[13px] font-black bg-green-50 text-green-700 border border-green-100">
                                    ₹@user.Balance.ToString("N2")
                                </div>
                            </td>
                            <td class="px-10 py-8 text-right">
                                <div class="flex justify-end gap-3">
                                    <a asp-action="UserDetails" asp-route-id="@user.UserId" class="w-10 h-10 flex items-center justify-center bg-[#fdf9f0] text-[#735c00] rounded-xl hover:bg-[#d4af37] hover:text-white transition-all shadow-sm" title="View Profile">
                                        <span class="material-symbols-outlined text-xl">visibility</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="px-10 py-24 text-center">
                                <div class="flex flex-col items-center gap-4">
                                    <div class="w-20 h-20 bg-[#fdf9f0] rounded-full flex items-center justify-center">
                                        <span class="material-symbols-outlined text-[#d4af37] text-4xl">person_search</span>
                                    </div>
                                    <p class="text-[#6c757d] font-bold">No registered users found in the system repository.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between mt-8">
        <p class="text-sm text-[#6c757d] font-bold">
            Showing @Model.Count of @ViewBag.TotalCount entries
        </p>
        <div class="flex gap-2">
            @if (ViewBag.Page > 1)
            {
                <a asp-action="Users" asp-route-page="@(ViewBag.Page - 1)" class="px-4 py-2 bg-white border border-[#efe7da] text-[#4d4635] font-bold rounded-lg hover:border-[#d4af37] transition no-underline">
                    Previous
                </a>
            }
            <span class="px-4 py-2 bg-[#fdf9f0] border border-[#d4af37] text-[#735c00] font-bold rounded-lg">
                @ViewBag.Page
            </span>
            @if (Model.Count == 10)
            {
                <a asp-action="Users" asp-route-page="@(ViewBag.Page + 1)" class="px-4 py-2 bg-white border border-[#efe7da] text-[#4d4635] font-bold rounded-lg hover:border-[#d4af37] transition no-underline">
                    Next
                </a>
            }
        </div>
    </div>
</div>
