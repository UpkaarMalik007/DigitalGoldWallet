@model List<DigitalGoldWallet.MVC.ViewModels.Vendor.VendorViewModel>
@{
    ViewData["Title"] = "Manage Vendors";
    Layout = "_AdminLayout";
}

<div class="space-y-12">
    <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-8">
        <div>
            <h1 class="text-4xl font-black text-[#1f1b13] tracking-tight">Supply Network</h1>
            <p class="text-[#6c757d] text-lg mt-2">Oversee and verify all partner vendors and gold providers.</p>
        </div>
        <div class="flex items-center gap-4">
            <div class="bg-white px-6 py-3 rounded-2xl border border-[#efe7da] shadow-sm flex items-center gap-4">
                <span class="text-sm font-black text-[#a58b3d] uppercase tracking-widest">Total Vendors</span>
                <span class="text-3xl font-black text-[#1f1b13]">@ViewBag.TotalCount</span>
            </div>
            <a asp-action="CreateVendor" class="px-8 py-4 bg-[#d4af37] text-[#554300] font-black rounded-2xl shadow-lg shadow-[#d4af37]/20 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center gap-2 no-underline">
                <span class="material-symbols-outlined">add_business</span>
                Onboard Vendor
            </a>
        </div>
    </div>

    <div class="bg-white rounded-[40px] border border-[#efe7da] shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-[#fbf3e5]/50">
                        <th class="px-6 py-5 text-[11px] font-black text-[#735c00] uppercase tracking-[0.2em]">Partner Identity</th>
                        <th class="px-6 py-5 text-[11px] font-black text-[#735c00] uppercase tracking-[0.2em]">Communication</th>
                        <th class="px-6 py-5 text-[11px] font-black text-[#735c00] uppercase tracking-[0.2em]">Gold Valuation</th>
                        <th class="px-6 py-5 text-[11px] font-black text-[#735c00] uppercase tracking-[0.2em]">Status</th>
                        <th class="px-6 py-5 text-[11px] font-black text-[#735c00] uppercase tracking-[0.2em]">Operations</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#fbf3e5]">
                    @foreach (var vendor in Model)
                    {
                        <tr class="hover:bg-[#fdf9f0]/30 transition-colors group">
                            <td class="px-6 py-6">
                                <div class="flex items-center gap-3">
                                    <div class="w-11 h-11 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center font-black text-lg border-2 border-amber-100 shadow-sm flex-shrink-0">
                                        @(vendor.VendorName != null ? vendor.VendorName.Substring(0, 1).ToUpper() : "V")
                                    </div>
                                    <div class="min-w-0">
                                        <div class="font-black text-[#1f1b13] truncate">@vendor.VendorName</div>
                                        <div class="text-[10px] font-bold text-[#a58b3d] uppercase tracking-widest mt-0.5 truncate">@vendor.WebsiteUrl</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-6">
                                <div class="space-y-1">
                                    <div class="flex items-center gap-1.5 text-sm font-semibold text-[#4d4635]">
                                        <span class="material-symbols-outlined text-[#6c757d] text-base flex-shrink-0">alternate_email</span>
                                        <span class="truncate">@vendor.ContactEmail</span>
                                    </div>
                                    <div class="flex items-center gap-1.5 text-xs text-[#6c757d]">
                                        <span class="material-symbols-outlined text-base flex-shrink-0">call</span>
                                        @vendor.ContactPhone
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-6">
                                <div class="text-lg font-black text-[#735c00]">
                                    ₹@vendor.CurrentGoldPrice?.ToString("N2")
                                    <span class="text-[10px] text-[#6c757d] font-bold">/gm</span>
                                </div>
                            </td>
                            <td class="px-6 py-6">
                                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-black bg-green-50 text-green-700 border border-green-100 uppercase tracking-widest">
                                    <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                                    Active
                                </span>
                            </td>
                            <td class="px-6 py-6">
                                <div class="flex items-center gap-2">
                                    <a asp-action="VendorDetails" asp-route-id="@vendor.VendorId" class="w-9 h-9 flex items-center justify-center bg-[#fdf9f0] text-[#735c00] rounded-xl hover:bg-[#d4af37] hover:text-white transition-all shadow-sm" title="View Analytics">
                                        <span class="material-symbols-outlined text-lg">analytics</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-24 text-center">
                                <div class="flex flex-col items-center gap-4">
                                    <div class="w-20 h-20 bg-[#fdf9f0] rounded-full flex items-center justify-center">
                                        <span class="material-symbols-outlined text-[#d4af37] text-4xl">business_messages</span>
                                    </div>
                                    <p class="text-[#6c757d] font-bold text-lg">No active supply partners detected in system.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between mt-8">
        <p class="text-sm text-[#6c757d] font-bold">
            Showing @Model.Count of @ViewBag.TotalCount entries
        </p>
        <div class="flex gap-2">
            @if (ViewBag.Page > 1)
            {
                <a asp-action="Vendors" asp-route-page="@(ViewBag.Page - 1)" class="px-4 py-2 bg-white border border-[#efe7da] text-[#4d4635] font-bold rounded-lg hover:border-[#d4af37] transition no-underline">
                    Previous
                </a>
            }
            <span class="px-4 py-2 bg-[#fdf9f0] border border-[#d4af37] text-[#735c00] font-bold rounded-lg">
                @ViewBag.Page
            </span>
            @if (Model.Count == 10)
            {
                <a asp-action="Vendors" asp-route-page="@(ViewBag.Page + 1)" class="px-4 py-2 bg-white border border-[#efe7da] text-[#4d4635] font-bold rounded-lg hover:border-[#d4af37] transition no-underline">
                    Next
                </a>
            }
        </div>
    </div>
</div>
