@model DigitalGoldWallet.MVC.Models.RegisterViewModel
@{
    ViewData["Title"] = "Add User";
    Layout = "_AdminLayout";
}

<div class="max-w-2xl mx-auto space-y-8">
    <div class="flex items-center gap-4">
        <a asp-action="Users" class="p-2 hover:bg-gray-100 rounded-full transition">
            <span class="material-symbols-outlined text-[#735c00]">arrow_back</span>
        </a>
        <h1 class="text-3xl font-extrabold text-[#1f1b13]">Add New User</h1>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded-r-xl">
            <p class="text-sm text-red-700">@ViewBag.Error</p>
        </div>
    }

    <div class="bg-white p-8 rounded-2xl border border-[#efe7da] shadow-sm">
        <form asp-action="CreateUser" method="post" class="space-y-6">
            <div>
                <label asp-for="Name" class="block text-sm font-bold text-[#4d4635] mb-2">Full Name</label>
                <input asp-for="Name" class="w-full px-4 py-3 rounded-xl border border-[#efe7da] focus:border-[#d4af37] focus:ring-2 focus:ring-[#fdf9f0] outline-none transition" placeholder="Enter user's full name" />
                <span asp-validation-for="Name" class="text-xs text-red-500 mt-1"></span>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-bold text-[#4d4635] mb-2">Email Address</label>
                <input asp-for="Email" class="w-full px-4 py-3 rounded-xl border border-[#efe7da] focus:border-[#d4af37] focus:ring-2 focus:ring-[#fdf9f0] outline-none transition" placeholder="user@example.com" />
                <span asp-validation-for="Email" class="text-xs text-red-500 mt-1"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-bold text-[#4d4635] mb-2">Account Password</label>
                <input asp-for="Password" type="password" class="w-full px-4 py-3 rounded-xl border border-[#efe7da] focus:border-[#d4af37] focus:ring-2 focus:ring-[#fdf9f0] outline-none transition" placeholder="Create a secure password" />
                <span asp-validation-for="Password" class="text-xs text-red-500 mt-1"></span>
            </div>

            <div class="pt-6 border-t border-[#fbf3e5] flex gap-4">
                <button type="submit" class="flex-1 px-6 py-3 bg-[#d4af37] text-[#554300] font-bold rounded-xl shadow-sm hover:shadow-md transition">
                    Create Account
                </button>
                <a asp-action="Users" class="flex-1 px-6 py-3 bg-white border border-[#efe7da] text-[#4d4635] font-bold rounded-xl text-center no-underline hover:bg-gray-50 transition">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
