@model DigitalGoldWallet.MVC.ViewModels.User.UserViewModel

@{
    ViewData["Title"] = "Profile";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="max-w-6xl mx-auto">

    <section class="mb-10">
        <h1 class="text-4xl font-bold text-[#1f1b13] mb-2">
            User Profile
        </h1>

        <p class="text-[#5f5e5e] text-lg">
            Manage your personal information and address details.
        </p>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <div class="bg-white rounded-2xl border border-[#e9ecef] shadow-sm p-8 flex flex-col items-center">

            <div class="w-28 h-28 rounded-full bg-[#d4af37] flex items-center justify-center text-white text-4xl font-bold mb-6">
                @Model.Name.Substring(0, 1).ToUpper()
            </div>

            <h2 class="text-2xl font-bold text-[#1f1b13] mb-2">
                @Model.Name
            </h2>

            <p class="text-[#6c757d] mb-6">
                Gold Investor
            </p>

            <div class="bg-[#fbf3e5] text-[#735c00] px-5 py-2 rounded-full font-semibold text-sm">
                Verified Account
            </div>

            <div class="mt-8 w-full">

                <div class="flex justify-between py-3 border-b border-[#e9ecef]">
                    <span class="text-[#6c757d]">Wallet Balance</span>
                    <span class="font-semibold text-[#1f1b13]">
                        ₹ @Model.Balance.ToString("N2")
                    </span>
                </div>

                <div class="flex justify-between py-3">
                    <span class="text-[#6c757d]">Status</span>
                    <span class="text-green-600 font-semibold">
                        Active
                    </span>
                </div>

            </div>

        </div>

        <div class="lg:col-span-2 flex flex-col gap-6">

            <div class="bg-white rounded-2xl border border-[#e9ecef] shadow-sm p-8">

                <div class="flex justify-between items-center mb-8">
                    <h3 class="text-2xl font-semibold text-[#1f1b13]">
                        Personal Information
                    </h3>

                    <a asp-action="EditProfile"
                       class="text-[#735c00] font-semibold text-sm flex items-center gap-1 hover:underline">
                        <span class="material-symbols-outlined text-base">edit</span>
                        Edit
                    </a>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                    <div>
                        <label class="block text-sm uppercase tracking-wider text-[#6c757d] mb-2">
                            Full Name
                        </label>

                        <div class="bg-[#f8f9fa] border border-[#e9ecef] rounded-xl px-4 py-3 text-[#1f1b13] font-medium">
                            @Model.Name
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm uppercase tracking-wider text-[#6c757d] mb-2">
                            Email Address
                        </label>

                        <div class="bg-[#f8f9fa] border border-[#e9ecef] rounded-xl px-4 py-3 text-[#1f1b13] font-medium">
                            @Model.Email
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm uppercase tracking-wider text-[#6c757d] mb-2">
                            Account Type
                        </label>

                        <div class="bg-[#f8f9fa] border border-[#e9ecef] rounded-xl px-4 py-3 text-[#1f1b13] font-medium">
                            User
                        </div>
                    </div>

                </div>

            </div>

            <div class="bg-white rounded-2xl border border-[#e9ecef] shadow-sm p-8">

                <div class="flex justify-between items-center mb-8">
                    <h3 class="text-2xl font-semibold text-[#1f1b13]">
                        Address Information
                    </h3>

                    <a asp-action="EditAddress"
                       class="text-[#735c00] font-semibold text-sm flex items-center gap-1 hover:underline">
                        <span class="material-symbols-outlined text-base">edit</span>
                        Edit
                    </a>
                </div>

                @if (Model.Address != null)
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                        <div class="md:col-span-2">
                            <label class="block text-sm uppercase tracking-wider text-[#6c757d] mb-2">
                                Full Address
                            </label>

                            <div class="bg-[#f8f9fa] border border-[#e9ecef] rounded-xl px-4 py-4 text-[#1f1b13] font-medium leading-7">
                                @Model.Address.Street,
                                @Model.Address.City,
                                @Model.Address.State -
                                @Model.Address.PostalCode,
                                @Model.Address.Country
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm uppercase tracking-wider text-[#6c757d] mb-2">
                                City
                            </label>

                            <div class="bg-[#f8f9fa] border border-[#e9ecef] rounded-xl px-4 py-3 text-[#1f1b13] font-medium">
                                @Model.Address.City
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm uppercase tracking-wider text-[#6c757d] mb-2">
                                State
                            </label>

                            <div class="bg-[#f8f9fa] border border-[#e9ecef] rounded-xl px-4 py-3 text-[#1f1b13] font-medium">
                                @Model.Address.State
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm uppercase tracking-wider text-[#6c757d] mb-2">
                                Postal Code
                            </label>

                            <div class="bg-[#f8f9fa] border border-[#e9ecef] rounded-xl px-4 py-3 text-[#1f1b13] font-medium">
                                @Model.Address.PostalCode
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm uppercase tracking-wider text-[#6c757d] mb-2">
                                Country
                            </label>

                            <div class="bg-[#f8f9fa] border border-[#e9ecef] rounded-xl px-4 py-3 text-[#1f1b13] font-medium">
                                @Model.Address.Country
                            </div>
                        </div>

                    </div>
                }
                else
                {
                    <div class="bg-[#fff3cd] border border-[#ffe69c] text-[#664d03] rounded-xl px-6 py-4">
                        Address information not available.
                    </div>
                }

            </div>

        </div>

    </div>

</div>