@model DigitalGoldWallet.MVC.ViewModels.WalletDashboardViewModel

@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

@if (TempData["Success"] != null)
{
    <script>
        alert('@TempData["Success"]');
    </script>
}

<div class="container-fluid">

    <!-- Wallet Balance -->
    <partial name="_WalletBalance" model="Model" />

    <!-- Action Buttons -->
    <partial name="_WalletActions" />

    <!-- Recent Transactions -->
    <partial name="_RecentTransactions" model="Model.RecentTransactions" />

</div>