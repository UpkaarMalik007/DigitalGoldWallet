@model DigitalGoldWallet.MVC.ViewModels.Gold.TransactionHistoryViewModel

@{
    ViewData["Title"] = "Transaction History";
}

<div class="container">
    <div class="hero-section mb-5">
        <h1 class="h2 mb-2">Statement of <span class="text-gold-dark">Transactions</span></h1>
        <p class="text-secondary">A comprehensive record of your digital gold activity.</p>
    </div>

    <div class="card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-cream">
                    <tr>
                        <th class="ps-4 py-3 text-secondary text-uppercase smaller ls-1">Date</th>
                        <th class="py-3 text-secondary text-uppercase smaller ls-1">Transaction ID</th>
                        <th class="py-3 text-secondary text-uppercase smaller ls-1 text-center">Type</th>
                        <th class="py-3 text-secondary text-uppercase smaller ls-1">Quantity</th>
                        <th class="py-3 text-secondary text-uppercase smaller ls-1">Amount</th>
                        <th class="pe-4 py-3 text-secondary text-uppercase smaller ls-1 text-center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tx in Model.Transactions)
                    {
                        <tr>
                            <td class="ps-4 py-4 text-secondary">
                                <div class="fw-bold text-dark-brown">@tx.Date.ToString("dd MMM yyyy")</div>
                                <small class="text-muted">@tx.Date.ToString("hh:mm tt")</small>
                            </td>
                            <td class="py-4 fw-600 text-secondary">#@tx.TransactionId</td>
                            <td class="py-4 text-center">
                                @if (tx.Type == "Buy")
                                {
                                    <span class="fw-bold text-success">Buy</span>
                                }
                                else if (tx.Type == "Sell")
                                {
                                    <span class="fw-bold text-danger">Sell</span>
                                }
                                else
                                {
                                    <span class="fw-bold text-primary">Convert</span>
                                }
                            </td>
                            <td class="py-4 text-dark-brown fw-600">
                                @(tx.Type == "Sell" ? "-" : "+")@tx.Quantity.ToString("N3") gm
                            </td>
                            <td class="py-4 fw-bold">
                                @if (tx.Amount > 0)
                                {
                                    <span class="@(tx.Type == "Buy" ? "text-danger" : "text-success")">
                                        @(tx.Type == "Buy" ? "-" : "+") @tx.Amount.ToString("C")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">--</span>
                                }
                            </td>
                            <td class="pe-4 py-4 text-center">
                                <span class="badge @(tx.Status == "Completed" ? "bg-dark-brown text-gold-primary" : "bg-light text-secondary") px-3 py-2 rounded-3 border-gold">
                                    @tx.Status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white border-0 p-4 d-flex justify-content-between align-items-center">
            <div class="text-secondary small">
                Showing page <strong>@Model.CurrentPage</strong> of <strong>@Model.TotalPages</strong>
            </div>
            <nav aria-label="Transaction pagination">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link border-gold text-dark-brown" asp-action="Transactions" asp-route-page="@(Model.CurrentPage - 1)" aria-label="Previous">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link @(i == Model.CurrentPage ? "bg-gold-dark border-gold text-white" : "border-gold text-dark-brown")" asp-action="Transactions" asp-route-page="@i">@i</a>
                        </li>
                    }

                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link border-gold text-dark-brown" asp-action="Transactions" asp-route-page="@(Model.CurrentPage + 1)" aria-label="Next">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
