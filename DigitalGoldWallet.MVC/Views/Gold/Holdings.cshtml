@{
    ViewData["Title"] = "Gold Holdings";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="max-w-7xl mx-auto">
    <section class="mb-10 flex justify-between items-end">
        <div>
            <h1 class="text-4xl font-bold text-[#1f1b13] mb-2">
                Gold Holdings
            </h1>
            <p class="text-[#5f5e5e] text-lg">
                Manage your digital gold assets and view your portfolio performance.
            </p>
        </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <div class="bg-white p-8 rounded-2xl border border-[#e9ecef] shadow-sm">
            <h3 class="text-lg font-semibold text-[#6c757d] uppercase tracking-wider mb-4">Total Assets</h3>
            <div class="text-5xl font-bold text-[#1f1b13] mb-2">0.00 g</div>
            <p class="text-sm text-[#5f5e5e]">Institutional-grade digital gold</p>
        </div>

        <div class="bg-[#343027] p-8 rounded-2xl text-white relative overflow-hidden">
            <h3 class="text-lg font-semibold opacity-70 uppercase tracking-wider mb-4">Portfolio Value</h3>
            <div class="text-5xl font-bold mb-2">₹ 0.00</div>
            <p class="text-sm opacity-70">Based on live market rates</p>
        </div>
    </div>

    <div class="bg-white rounded-2xl border border-[#e9ecef] shadow-sm p-12 text-center">
        <div class="w-24 h-24 bg-[#fbf3e5] rounded-full flex items-center justify-center mx-auto mb-8">
            <span class="material-symbols-outlined text-[#d4af37] text-5xl">payments</span>
        </div>
        <h3 class="text-3xl font-bold text-[#1f1b13] mb-4">Start your gold journey</h3>
        <p class="text-[#6c757d] max-w-lg mx-auto text-lg mb-10">
            Investing in digital gold is secure, transparent, and simple. Your portfolio details will appear here once the feature is fully active.
        </p>
    </div>
</div>
