@model DigitalGoldWallet.MVC.ViewModels.Gold.PhysicalHistoryViewModel

@{
    ViewData["Title"] = "Physical Gold History";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<div class="container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 p-3 mb-4 d-flex align-items-center">
            <i class="bi bi-check-circle-fill fs-4 me-3"></i>
            <div>@TempData["SuccessMessage"]</div>
            <button type="button" class="btn-close ms-auto shadow-none" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="hero-section mb-5">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="h2 mb-2">Physical <span class="text-gold-dark">History</span></h1>
                <p class="text-secondary mb-0">Complete record of your physical gold redemptions.</p>
            </div>
            <div class="col-md-6 text-md-end mt-3 mt-md-0">
                <a asp-action="ConvertToPhysical" class="btn btn-gold px-4 py-2 shadow-sm">
                    <i class="bi bi-arrow-left-right me-2"></i>New Conversion
                </a>
            </div>
        </div>
    </div>

    <div class="card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-cream">
                    <tr>
                        <th class="ps-4 py-3 text-secondary text-uppercase smaller ls-1">Request ID & Date</th>
                        <th class="py-3 text-secondary text-uppercase smaller ls-1">Quantity</th>
                        <th class="py-3 text-secondary text-uppercase smaller ls-1">Branch & Destination</th>
                        <th class="pe-4 py-3 text-secondary text-uppercase smaller ls-1 text-center">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var conv in Model.Conversions)
                    {
                        <tr>
                            <td class="ps-4 py-4">
                                <div class="fw-bold text-dark-brown">#@conv.ConversionId</div>
                                <small class="text-secondary">@conv.RequestDate.ToString("dd MMM yyyy")</small>
                            </td>
                            <td class="py-4">
                                <div class="text-dark-brown fw-600">@conv.Quantity.ToString("N3") gm</div>
                                <small class="text-muted">24K Pure Gold</small>
                            </td>
                            <td class="py-4">
                                <div class="fw-bold text-secondary">@conv.BranchName</div>
                                <small class="text-muted d-block" style="max-width: 250px;">
                                    <i class="bi bi-geo-alt-fill smaller"></i> @conv.DeliveryAddress
                                </small>
                            </td>
                            <td class="pe-4 py-4 text-center">
                                @if (conv.DeliveryStatus == "Delivered")
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">
                                        <i class="bi bi-check-circle me-1"></i> Delivered
                                    </span>
                                }
                                else if (conv.DeliveryStatus == "In Transit")
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill">
                                        <i class="bi bi-truck me-1"></i> @conv.DeliveryStatus
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-pill">
                                        <i class="bi bi-clock me-1"></i> @conv.DeliveryStatus
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
