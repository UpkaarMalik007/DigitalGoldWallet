@section Scripts {

                    <script>
                                        $(document).ready(function () {

                                            var price = @Html.Raw(
                                                                            Model.CurrentGoldPrice.ToString(
                                                                                    System.Globalization.CultureInfo.InvariantCulture));

                                            $('#Amount').on('input', function () {

                                                var amount = parseFloat($(this).val());

                                                if (amount > 0) {

                                                    var qty = amount / price;

                                                    $('#estimatedQuantity').html(
                                                        qty.toFixed(3) + ' <small class="fs-6">gm</small>');

                                                    $('#quantityHidden').val(qty.toFixed(3));
                                                }
                                                else {

                                                    $('#estimatedQuantity').html(
                                                        '0.000 <small class="fs-6">gm</small>');

                                                    $('#quantityHidden').val(0);
                                                }
                                            });

                                            $('#SelectedBranch').on('change', function () {

                                                $('#branchIdHidden').val($(this).val());
                                            });
                                        });
                    </script>
                }
