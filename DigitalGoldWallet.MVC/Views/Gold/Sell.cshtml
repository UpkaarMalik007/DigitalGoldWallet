@model DigitalGoldWallet.MVC.ViewModels.Gold.SellGoldViewModel

@{
    ViewData["Title"] = "Redeem Gold";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="hero-section text-center mb-4">
                <h1 class="h2">Instant <span class="text-gold-dark">Redemption</span></h1>
                <p class="text-secondary">Convert your digital gold holdings back to currency.</p>
            </div>

            <div class="card p-5">
                <div class="row g-2 mb-5 text-center">
                    <div class="col-6">
                        <div class="p-3 bg-cream rounded-4 h-100">
                            <small class="text-secondary text-uppercase ls-1 d-block mb-1">Your Balance</small>
                            <h5 class="mb-0 text-dark-brown">@Model.GoldBalance.ToString("N3") gm</h5>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-cream rounded-4 h-100">
                            <small class="text-secondary text-uppercase ls-1 d-block mb-1">Sell Price</small>
                            <h5 class="mb-0 text-dark-brown">@Model.CurrentGoldPrice.ToString("C")</h5>
                        </div>
                    </div>
                </div>

                <form asp-action="Sell" method="post">
                    <div class="row g-4">
                        <div class="col-12">
                            <label asp-for="Quantity" class="form-label text-secondary fw-bold small">Quantity to Sell (gm)</label>
                            <div class="input-group">
                                <input asp-for="Quantity" class="form-control" placeholder="0.000" />
                                <span class="input-group-text bg-cream border-medium text-secondary">gm</span>
                            </div>
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="SelectedBranch" class="form-label text-secondary fw-bold small">Select Redemption Branch</label>
                            <select asp-for="SelectedBranch" class="form-select form-control">
                                <option value="">Choose a branch...</option>
                                @foreach (var branch in Model.Branches)
                                {
                                    <option value="@branch.BranchId">
                                        @branch.BranchName (@branch.VendorName) - @branch.Address
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="SelectedBranch" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <div class="text-center p-4 rounded-4 bg-cream border border-light">
                                <small class="text-secondary d-block mb-1">Estimated Credit Amount</small>
                                <h3 class="mb-0 text-gold-dark" id="estimatedAmount">₹ 0.00</h3>
                            </div>
                        </div>

                        <div class="col-12 mt-4">
                            <button type="submit" class="btn btn-gold w-100 py-3 shadow">Redeem to Bank</button>
                        </div>
                    </div>
                    
                    <div class="mt-4 text-center">
                        <small class="text-secondary">Funds will be credited to your linked bank account instantly.</small>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var price = @Html.Raw(Model.CurrentGoldPrice.ToString(System.Globalization.CultureInfo.InvariantCulture));
            $('#Quantity').on('input', function() {
                var qty = parseFloat($(this).val());
                if (!isNaN(qty) && qty > 0) {
                    var amount = qty * price;
                    $('#estimatedAmount').text('₹ ' + amount.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));
                } else {
                    $('#estimatedAmount').text('₹ 0.00');
                }
            });
        });
    </script>
}
